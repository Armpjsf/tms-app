# Supabase Configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"

# DTC GPS Integration
DTC_USER="ddpakchong"
DTC_PASS="DDGPS"
DTC_API_URL="https://gps.dtc.co.th/backendv2/api/v1/auth/login"
DTC_REALTIME_URL="https://gps.dtc.co.th/backendv2/api/v1/ultimate/realtime"
DTC_TOKEN=""

# Debug Mode
TMS_DEBUG="0"

# Timezone — Vercel/Node runs in UTC by default. All date/time logic goes through
# src/lib/utils/date-th.ts (Asia/Bangkok), but set this in the Vercel project's
# Environment Variables too so any remaining local-time Date methods use Thai time.
TZ="Asia/Bangkok"

# LINE LIFF Configuration
NEXT_PUBLIC_APP_URL="https://your-production-url.vercel.app"
NEXT_PUBLIC_LIFF_SIGNATURE_ID="your-liff-app-id-here"
